---
layout: null
---
[
  {% assign pages = site.pages | where_exp: "p", "p.title != nil" %}
  {% for page in pages %}
  {
    "title": {{ page.title | jsonify }},
    "url": "{{ page.url | relative_url }}",
    "content": {{ page.content | strip_html | truncatewords: 200 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
